    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "pyodide": "^314.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-resizable-panels": "^4.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
