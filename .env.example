# ------------------------------------------------------------------
# Katalume frontend environment configuration
# Copy to .env.local and fill in. Vars prefixed NEXT_PUBLIC_ are
# exposed to the browser — never put secrets in them.
# ------------------------------------------------------------------

# API mode: "mock" (in-file data), "live" (real backend), or "auto".
# Defaults to "mock". Set to "live" for production.
NEXT_PUBLIC_API_MODE=mock

# Server-only backend origin used by the same-origin /api BFF proxy.
# Never prefix this variable with NEXT_PUBLIC_.
BACKEND_API_URL=http://localhost:5001/api

# Optional direct browser API override for local diagnostics only.
# Leave blank in production so all traffic uses the same-origin BFF.
NEXT_PUBLIC_API_URL=

# Live route protection validates the backend's signed httpOnly session server-to-server.

# In live mode, whether to silently fall back to mock data on API failure.
# Set to "false" in production so real failures surface instead of hiding.
NEXT_PUBLIC_API_FALLBACK_TO_MOCK=true

# Request tuning
NEXT_PUBLIC_API_RETRY_COUNT=2
NEXT_PUBLIC_API_TIMEOUT_MS=8000

# Canonical public origin, used for metadata, sitemap, and social previews.
# Production example: https://katalume.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App environment label (used for observability tagging)
NEXT_PUBLIC_APP_ENV=development

# Optional analytics endpoint (events are dropped if unset)
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# Sentry — client DSN is public-safe; server DSN is server-only.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Backend origin for social-login (OAuth) start/callback redirects. Point at the
# API subdomain, e.g. https://api.katalume.com. Leave blank for the mock demo.
# For first-party session cookies, deploy the web app and API on the same parent
# domain and set the backend COOKIE_DOMAIN=.katalume.com
NEXT_PUBLIC_BACKEND_ORIGIN=
