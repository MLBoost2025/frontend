# ------------------------------------------------------------------
# MLBoost frontend environment configuration
# Copy to .env.local and fill in. Vars prefixed NEXT_PUBLIC_ are
# exposed to the browser — never put secrets in them.
# ------------------------------------------------------------------

# API mode: "mock" (in-file data), "live" (real backend), or "auto".
# Defaults to "mock". Set to "live" for production.
NEXT_PUBLIC_API_MODE=mock

# Base URL of the backend API (used in live/auto mode).
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# Live route protection validates the backend's signed httpOnly session at this URL.
# Deploy frontend/backend under a shared cookie domain for production middleware access.

# In live mode, whether to silently fall back to mock data on API failure.
# Set to "false" in production so real failures surface instead of hiding.
NEXT_PUBLIC_API_FALLBACK_TO_MOCK=true

# Request tuning
NEXT_PUBLIC_API_RETRY_COUNT=2
NEXT_PUBLIC_API_TIMEOUT_MS=8000

# App environment label (used for observability tagging)
NEXT_PUBLIC_APP_ENV=development

# Optional analytics endpoint (events are dropped if unset)
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# Sentry — client DSN is public-safe; server DSN is server-only.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
